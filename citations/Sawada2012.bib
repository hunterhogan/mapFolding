@article{Sawada_2012,
    author = {Sawada, Joe and Li, Roy},
    title = {Stamp Foldings, Semi-Meanders, and Open Meanders: Fast Generation Algorithms},
    journal = {The Electronic Journal of Combinatorics},
    volume = {19},
    number = {2},
    pages = {P43},
    year = {2012},
    month = {June},
    doi = {10.37236/2404},
    url = {https://doi.org/10.37236/2404},
    abstract = {By considering a permutation representation for stamp-foldings and semi-meanders we construct tree-like data structures that will allow us to generate these objects in constant amortized time. Additionally, by maintaining the wind-factor and applying an additional optimization, the algorithm for semi-meanders can be modified to produce the fastest known algorithm to generate open meanders.}
}
